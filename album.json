{
  "info": {
    "name": "Album API Tests",
    "description": "5 API tests for the Album resource",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Get All Albums",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/albums",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "albums"
          ]
        },
        "description": "Fetch a list of all albums"
      },
      "response": []
    },
    {
      "name": "2. Create Album",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"title\": \"My Awesome Album\",\n    \"artist\": \"Great Artist\",\n    \"year\": 2024\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/albums",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "albums"
          ]
        },
        "description": "Create a new album"
      },
      "response": []
    },
    {
      "name": "3. Get Single Album",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/albums/{{albumId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "albums",
            "{{albumId}}"
          ]
        },
        "description": "Fetch a single album by its ID"
      },
      "response": []
    },
    {
      "name": "4. Update Album",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"title\": \"Updated Album Title\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/albums/{{albumId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "albums",
            "{{albumId}}"
          ]
        },
        "description": "Update an existing album"
      },
      "response": []
    },
    {
      "name": "5. Delete Album",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/albums/{{albumId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "albums",
            "{{albumId}}"
          ]
        },
        "description": "Delete an album by its ID"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "albumId",
      "value": "REPLACE_WITH_ACTUAL_ID",
      "type": "string"
    }
  ]
}